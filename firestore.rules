rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to get user role
    function getUserRole() {
      let cust = get(/databases/$(database)/documents/customers/$(request.auth.uid));
      return cust != null ? cust.data.role : null;
    }
    
    // Function to check if superadmin
    function isSuperAdmin() {
      return getUserRole() == 'superadmin';
    }

    match /nodes/{nodeId} {
      // Superadmins read all. Customers read if node is assigned to them.
      allow read: if request.auth != null && (isSuperAdmin() || resource.data.customerId == request.auth.uid);
      allow write: if false; // Writes ONLY via Cloud Functions
    }

    match /customers/{customerId} {
      allow read: if request.auth != null && (isSuperAdmin() || request.auth.uid == customerId);
      allow write: if false; // Writes ONLY via Cloud Functions
    }
    
    match /communities/{document=**} {
      allow read: if request.auth != null; // Refine if communities must be isolated
      allow write: if false;
    }
    
    match /zones/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    match /audit_logs/{document=**} {
      allow read: if request.auth != null && isSuperAdmin();
      allow write: if false; // Cloud functions only
    }
  }
}

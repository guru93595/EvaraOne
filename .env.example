# ══════════════════════════════════════════════════════════════════════════════
# EVARA-TECH IoT SAAS — ENVIRONMENT TEMPLATE
# ══════════════════════════════════════════════════════════════════════════════

# --- SERVER CONFIG ---
PORT=8000
NODE_ENV=production
ALLOWED_ORIGINS=https://app.evaratech.com,http://localhost:8080

# --- REDIS (CACHE & PUB/SUB) ---
# Format: redis://[[user]:password@]host:port[/db-number]
# Render Internal: redis://red-xxxxxxxxxxxxxxx:6379
REDIS_URL=redis://localhost:6379

# --- FIREBASE ADMIN SDK ---
# Note: PRIVATE_KEY should have escaped newlines (\n)
FIREBASE_PROJECT_ID=evaratank
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@evaratank.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"
FIREBASE_TYPE=service_account
FIREBASE_DATABASE_URL=https://evaratank.firebaseio.com
FIREBASE_STORAGE_BUCKET=evaratank.appspot.com

# --- TELEMETRY ---
# Interval in milliseconds (5000 = 5s)
TELEMETRY_POLL_INTERVAL=5000

# --- MONITORING ---
SENTRY_DSN=
